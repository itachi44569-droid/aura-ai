# ════════════════════════════════════════════
#  AI BRAIN — Environment Variables
#  Copy this to .env and fill in your values
# ════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here          # Free: https://console.groq.com

# ── TELEGRAM (required if ENABLE_TG=true) ────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_token_here  # Free: message @BotFather on Telegram

# ── DISCORD (optional) ────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_token_here    # Free: https://discord.com/developers/applications
DISCORD_PREFIX=!                         # Command prefix: !ask, !help, !clear

# ── WHATSAPP (optional, free 1000 msgs/month) ─────────────────────────────────
WHATSAPP_TOKEN=your_meta_access_token    # From: developers.facebook.com
WHATSAPP_PHONE_ID=your_phone_number_id  # From: WhatsApp → API Setup
WHATSAPP_VERIFY_TOKEN=any-secret-string # You choose this — used to verify webhook

# ── CHANNELS TO ENABLE ────────────────────────────────────────────────────────
ENABLE_TG=true
ENABLE_WEB=false
ENABLE_DISCORD=false

# ── FEATURES ──────────────────────────────────────────────────────────────────
ENABLE_RAG=true              # ChromaDB knowledge base
ENABLE_REFLECTION=false      # Self-reflection loop (improves quality, adds latency)
RATE_MESSAGES_PER_MIN=20     # Max messages per user per minute
RATE_MESSAGES_PER_DAY=200    # Max messages per user per day

# ── PERSONALITY ───────────────────────────────────────────────────────────────
CLIENT_NAME=default          # Options: default | finance | business

# ── PATHS & PORTS ─────────────────────────────────────────────────────────────
WEB_PORT=8000
DB_PATH=brain.db
CHROMA_PATH=./chroma_db
TIMEZONE=Asia/Kolkata        # For reminders/scheduler
